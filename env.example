# ─────────────────────────────────────────────
# WINSTON PUMP SNIPER - ENVIRONMENT CONFIG
# ─────────────────────────────────────────────

# ─── WALLET ───
# Base58 private key from Phantom/Solflare
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ─── RPC ───
# Helius recommended: https://helius.dev
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
HELIUS_API_KEY=your_helius_api_key_here

# ─── DISCORD ───
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ─── JUPITER (optional but faster with key) ───
JUPITER_API_KEY=

# ─── TRADE SETTINGS ───
TRADE_AMOUNT_SOL=0.012
MAX_OPEN_POSITIONS=2
SLIPPAGE_BPS=1000

# ─── EXIT SETTINGS ───
TP1_MULTIPLIER=1.5        # take 40% profit at 1.5x
TP1_SELL_PCT=40
TP2_MULTIPLIER=2.5        # take 40% more at 2.5x
TP2_SELL_PCT=40
TRAILING_STOP_PCT=12      # trail remainder with 12% stop
STOP_LOSS_PCT=18          # hard stop at -18%
MAX_HOLD_MINUTES=8        # hard timeout
PRICE_DEAD_SECONDS=90     # emergency sell if no price for 90s
SELL_RETRY_ATTEMPTS=10    # retries before emergency loop

# ─── FILTERS ───
MIN_HOLDERS=5             # min holder accounts
MAX_TOP_HOLDER_PCT=40     # reject if top holder > 40%
GREEN_WAIT_SECONDS=2      # wait before green momentum check
